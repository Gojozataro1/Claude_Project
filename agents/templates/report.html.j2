<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>AI Ops — Trend Report</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    :root {
      --bg: #0f1117; --surface: #1a1d27; --border: #2a2d3a;
      --text: #e2e8f0; --muted: #94a3b8; --accent: #6366f1;
      --green: #22c55e; --yellow: #f59e0b; --red: #ef4444; --blue: #3b82f6;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--bg); color: var(--text); font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; font-size: 14px; line-height: 1.6; }
    header { background: var(--surface); border-bottom: 1px solid var(--border); padding: 20px 32px; display: flex; justify-content: space-between; align-items: center; }
    header h1 { font-size: 20px; font-weight: 600; }
    header .meta { color: var(--muted); font-size: 12px; text-align: right; }
    .container { max-width: 1200px; margin: 0 auto; padding: 24px 32px; }
    .section-title { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); margin-bottom: 12px; }

    /* Stat cards */
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 16px; margin-bottom: 32px; }
    .stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 16px 20px; }
    .stat-card .label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); margin-bottom: 6px; }
    .stat-card .value { font-size: 28px; font-weight: 700; }
    .stat-card .sub { font-size: 11px; color: var(--muted); margin-top: 4px; }
    .color-green { color: var(--green); }
    .color-yellow { color: var(--yellow); }
    .color-red { color: var(--red); }
    .color-blue { color: var(--blue); }

    /* Charts */
    .charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 32px; }
    .chart-card { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 20px; }
    .chart-card h3 { font-size: 13px; font-weight: 600; margin-bottom: 16px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; }
    .chart-card canvas { max-height: 220px; }
    @media (max-width: 768px) { .charts-grid { grid-template-columns: 1fr; } }

    /* Tables */
    .table-card { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; margin-bottom: 24px; overflow: hidden; }
    .table-card h3 { font-size: 13px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; padding: 14px 20px; border-bottom: 1px solid var(--border); }
    table { width: 100%; border-collapse: collapse; }
    thead th { padding: 10px 16px; text-align: left; font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); border-bottom: 1px solid var(--border); }
    tbody td { padding: 10px 16px; border-bottom: 1px solid var(--border); vertical-align: top; }
    tbody tr:last-child td { border-bottom: none; }
    .badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
    .badge-critical { background: rgba(239,68,68,.15); color: var(--red); }
    .badge-warning  { background: rgba(245,158,11,.15); color: var(--yellow); }
    .badge-info     { background: rgba(99,102,241,.15); color: var(--accent); }
    .badge-stable   { background: rgba(34,197,94,.12); color: var(--green); }
    .badge-improving { background: rgba(34,197,94,.2); color: var(--green); }
    .badge-degrading { background: rgba(239,68,68,.2); color: var(--red); }

    /* Alerts */
    .alerts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px; margin-bottom: 32px; }
    .alert-stat { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 14px; }
    .alert-stat .al { font-size: 11px; text-transform: uppercase; color: var(--muted); margin-bottom: 4px; }
    .alert-stat .av { font-size: 22px; font-weight: 700; }

    /* Summary box */
    .summary-box { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 16px 20px; margin-bottom: 24px; color: var(--muted); font-size: 13px; }

    footer { text-align: center; padding: 24px; color: var(--muted); font-size: 12px; border-top: 1px solid var(--border); margin-top: 32px; }
  </style>
</head>
<body>

<header>
  <div>
    <h1>AI Ops — Trend Report</h1>
    <div style="color:var(--muted);font-size:12px;margin-top:4px;">{{ hostname }} &nbsp;·&nbsp; macOS {{ macos_version }}</div>
  </div>
  <div class="meta">
    <div>Generated {{ generated_at[:10] }}</div>
    <div>{{ total_scans }} scan{{ 's' if total_scans != 1 else '' }} analysed</div>
  </div>
</header>

<div class="container">

  <!-- Stat cards -->
  <div class="section-title" style="margin-top:8px;">Overview</div>
  <div class="stats-grid">
    <div class="stat-card">
      <div class="label">Latest Score</div>
      <div class="value {% if latest_score and latest_score >= 80 %}color-green{% elif latest_score and latest_score >= 60 %}color-yellow{% else %}color-red{% endif %}">
        {{ latest_score if latest_score is not none else 'N/A' }}
      </div>
      <div class="sub">out of 100</div>
    </div>
    <div class="stat-card">
      <div class="label">Average Score</div>
      <div class="value color-blue">{{ avg_score if avg_score is not none else 'N/A' }}</div>
      <div class="sub">across all scans</div>
    </div>
    <div class="stat-card">
      <div class="label">Score Range</div>
      <div class="value" style="font-size:20px;">{{ min_score }}–{{ max_score }}</div>
      <div class="sub">min – max</div>
    </div>
    <div class="stat-card">
      <div class="label">Trend</div>
      <div class="value" style="font-size:20px;">
        <span class="badge badge-{{ trend_direction }}">{{ trend_direction | title }}</span>
      </div>
      <div class="sub">latest vs previous scan</div>
    </div>
    <div class="stat-card">
      <div class="label">Total Scans</div>
      <div class="value color-blue">{{ total_scans }}</div>
      <div class="sub">archived results</div>
    </div>
    <div class="stat-card">
      <div class="label">Alerts Logged</div>
      <div class="value {% if alerts_summary.total > 0 %}color-yellow{% else %}color-green{% endif %}">
        {{ alerts_summary.total }}
      </div>
      <div class="sub">monitoring alerts</div>
    </div>
  </div>

  <!-- Charts -->
  <div class="section-title">Trends</div>
  <div class="charts-grid">
    <div class="chart-card">
      <h3>Health Score Over Time</h3>
      <canvas id="scoreChart"></canvas>
    </div>
    <div class="chart-card">
      <h3>Issue Categories (Latest Scan)</h3>
      <canvas id="categoryChart"></canvas>
    </div>
    <div class="chart-card">
      <h3>Priority Distribution (All Scans)</h3>
      <canvas id="priorityChart"></canvas>
    </div>
    {% if alerts_summary.total > 0 %}
    <div class="chart-card">
      <h3>Alerts by Metric</h3>
      <canvas id="alertChart"></canvas>
    </div>
    {% endif %}
  </div>

  <!-- Latest AI Summary -->
  {% if latest_summary %}
  <div class="section-title">Latest Scan Summary</div>
  <div class="summary-box">{{ latest_summary }}</div>
  {% endif %}

  <!-- Recurring issues -->
  {% if recurring_issues %}
  <div class="table-card">
    <h3>Recurring Issues <span style="font-weight:400;font-size:11px;">(appeared in multiple scans)</span></h3>
    <table>
      <thead>
        <tr>
          <th>Priority</th>
          <th>Category</th>
          <th>Issue</th>
          <th>Occurrences</th>
          <th>Impact</th>
        </tr>
      </thead>
      <tbody>
        {% for r in recurring_issues %}
        <tr>
          <td><span class="badge badge-{{ r.priority | lower }}">{{ r.priority }}</span></td>
          <td>{{ r.category }}</td>
          <td>{{ r.title }}</td>
          <td style="text-align:center;">{{ r.occurrence_count }}</td>
          <td style="color:var(--muted);">{{ r.estimated_impact }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}

  <!-- Latest suggestions -->
  {% if latest_suggestions %}
  <div class="table-card">
    <h3>Latest Scan — All Suggestions</h3>
    <table>
      <thead>
        <tr>
          <th>Priority</th>
          <th>Category</th>
          <th>Title</th>
          <th>Recommended Action</th>
          <th>Impact</th>
        </tr>
      </thead>
      <tbody>
        {% for s in latest_suggestions %}
        <tr>
          <td><span class="badge badge-{{ s.priority | lower }}">{{ s.priority }}</span></td>
          <td>{{ s.category }}</td>
          <td>{{ s.title }}</td>
          <td style="font-family:monospace;font-size:11px;color:var(--muted);">{{ s.action }}</td>
          <td style="color:var(--muted);">{{ s.estimated_impact }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}

  <!-- Alerts summary -->
  {% if alerts_summary.total > 0 %}
  <div class="section-title">Monitoring Alerts Summary</div>
  <div class="alerts-grid">
    <div class="alert-stat">
      <div class="al">Total Alerts</div>
      <div class="av color-yellow">{{ alerts_summary.total }}</div>
    </div>
    {% for sev, cnt in alerts_summary.by_severity.items() %}
    <div class="alert-stat">
      <div class="al">{{ sev | title }}</div>
      <div class="av {% if sev == 'critical' %}color-red{% else %}color-yellow{% endif %}">{{ cnt }}</div>
    </div>
    {% endfor %}
    {% for metric, cnt in alerts_summary.by_metric.items() %}
    <div class="alert-stat">
      <div class="al">{{ metric }}</div>
      <div class="av color-blue">{{ cnt }}</div>
    </div>
    {% endfor %}
  </div>
  {% endif %}

</div>

<footer>AI Ops Trend Report &nbsp;·&nbsp; Generated by Report Agent &nbsp;·&nbsp; {{ generated_at }}</footer>

<script>
const SCORE_DATA   = {{ score_series_json }};
const CATEGORY_DATA = {{ category_dist_json }};
const PRIORITY_DATA = {{ priority_dist_json }};

const PALETTE = ['#6366f1','#22c55e','#f59e0b','#ef4444','#3b82f6','#a855f7','#14b8a6'];
const gridColor = 'rgba(255,255,255,0.06)';
const tickColor = '#94a3b8';

// Score over time
if (SCORE_DATA.length) {
  const labels = SCORE_DATA.map(d => d.timestamp.slice(0,10));
  const values = SCORE_DATA.map(d => d.score);
  new Chart(document.getElementById('scoreChart'), {
    type: 'line',
    data: {
      labels,
      datasets: [{
        label: 'Health Score',
        data: values,
        borderColor: '#6366f1',
        backgroundColor: 'rgba(99,102,241,0.1)',
        fill: true,
        tension: 0.35,
        pointRadius: 4,
        pointBackgroundColor: '#6366f1',
      }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: {
        y: { min: 0, max: 100, grid: { color: gridColor }, ticks: { color: tickColor } },
        x: { grid: { color: gridColor }, ticks: { color: tickColor, maxRotation: 30 } },
      }
    }
  });
}

// Category doughnut
if (Object.keys(CATEGORY_DATA).length) {
  new Chart(document.getElementById('categoryChart'), {
    type: 'doughnut',
    data: {
      labels: Object.keys(CATEGORY_DATA),
      datasets: [{ data: Object.values(CATEGORY_DATA), backgroundColor: PALETTE, borderWidth: 0 }]
    },
    options: {
      responsive: true,
      plugins: { legend: { position: 'right', labels: { color: tickColor, boxWidth: 12 } } }
    }
  });
}

// Priority bar
if (Object.keys(PRIORITY_DATA).length) {
  const priorityColors = { Critical: '#ef4444', Warning: '#f59e0b', Info: '#6366f1' };
  new Chart(document.getElementById('priorityChart'), {
    type: 'bar',
    data: {
      labels: Object.keys(PRIORITY_DATA),
      datasets: [{
        data: Object.values(PRIORITY_DATA),
        backgroundColor: Object.keys(PRIORITY_DATA).map(k => priorityColors[k] || '#6366f1'),
        borderRadius: 4,
      }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: {
        y: { grid: { color: gridColor }, ticks: { color: tickColor } },
        x: { grid: { color: gridColor }, ticks: { color: tickColor } },
      }
    }
  });
}

// Alert by metric bar
const alertEl = document.getElementById('alertChart');
if (alertEl) {
  const alertData = {{ alerts_summary.by_metric | tojson }};
  new Chart(alertEl, {
    type: 'bar',
    data: {
      labels: Object.keys(alertData),
      datasets: [{
        data: Object.values(alertData),
        backgroundColor: '#f59e0b',
        borderRadius: 4,
      }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: {
        y: { grid: { color: gridColor }, ticks: { color: tickColor } },
        x: { grid: { color: gridColor }, ticks: { color: tickColor } },
      }
    }
  });
}
</script>
</body>
</html>
